<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Window/splash theme used before Compose takes over. Uses the platform
      Material theme so we don't need the Material Components library — all real
      UI is Compose (GamdoTheme). Charcoal window background per D10.
    -->
    <style name="Theme.Gamdo" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/charcoal_900</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
